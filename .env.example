# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get from neon.tech → your project → Connection Details
# DATABASE_URL  → use the "Pooled connection" string
# DIRECT_URL    → use the "Direct connection" string (for migrations)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/foodstocks?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxxx.neon.tech/foodstocks?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://supplier.foodstocks.id

# ─── Cron security (Vercel Cron) ─────────────────────────────────────────────
CRON_SECRET=your-cron-secret-key

# ─── WhatsApp Notification (Fonnte) — optional for MVP ───────────────────────
# Get from: fonnte.com → dashboard → token
# FONNTE_TOKEN=your-fonnte-api-token

# ─── Setup (run these once after filling in DB vars above) ───────────────────
# cp .env.example .env.local
# npx prisma db push      ← creates tables in Neon
# npm run db:seed         ← seeds with demo data
# npm run dev             ← start local server
