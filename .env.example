# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Database (Neon PostgreSQL) ─────────────────────────
# Get from: neon.tech → your project → connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/foodstocks?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/foodstocks?sslmode=require

# ─── WhatsApp Notification (Fonnte) ─────────────────────
# Get from: fonnte.com → dashboard → token
FONNTE_TOKEN=your-fonnte-api-token

# ─── Demo Mode (set true to skip DB, use mock data) ─────
USE_MOCK_DATA=true
